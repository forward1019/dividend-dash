# dividend-dash environment variables (copy to .env, never commit .env)

# === Required for AI dividend briefs (Phase 5) ===
ANTHROPIC_API_KEY=sk-ant-...

# === Required for weekly Discord digest (Phase 5) ===
# Either a webhook URL OR a bot token + channel ID
DISCORD_WEBHOOK_URL=
# DISCORD_BOT_TOKEN=
# DISCORD_CHANNEL_ID=

# === Optional: paid data fallback (Phase 1) ===
# Used only if yahoo-finance2 + SEC EDGAR sources fail.
POLYGON_API_KEY=

# === Optional: SEC EDGAR ===
# Required by SEC's fair-access policy. Format: "Name email@example.com"
SEC_EDGAR_USER_AGENT="dividend-dash forward1019@users.noreply.github.com"

# === Database location ===
# Default: ./data/dividend-dash.db
DD_DB_PATH=./data/dividend-dash.db

# === Logging ===
DD_LOG_LEVEL=info
