# dividend-dash environment variables (copy to .env, never commit .env)

# === Optional: AI dividend briefs (Phase 5) ===
# By default, `bun run brief` shells out to the local `claude` CLI and
# authenticates via your Claude Max OAuth credentials at
# ~/.claude/.credentials.json — no key needed. Set ANTHROPIC_API_KEY only
# if you want to bill against an API account instead (the `claude` binary
# auto-detects this env var). See docs/decisions.md for context.
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_BIN=/home/you/.local/bin/claude  # override binary path if not on PATH

# === Required for weekly Discord digest (Phase 5) ===
# Either a webhook URL OR a bot token + channel ID
DISCORD_WEBHOOK_URL=
# DISCORD_BOT_TOKEN=
# DISCORD_CHANNEL_ID=

# === Optional: paid data fallback (Phase 1) ===
# Used only if yahoo-finance2 + SEC EDGAR sources fail.
POLYGON_API_KEY=

# === Required: SEC EDGAR User-Agent ===
# SEC's fair-access policy requires a real, contactable identity in the User-Agent.
# Format: "Your Name your@real-email.com"  (or "Company Name admin@company.com")
# IMPORTANT: SEC's bot detector rejects generic / no-reply domains
# (e.g. users.noreply.github.com, example.com). Use a real personal or company email.
SEC_EDGAR_USER_AGENT="Your Name your@real-email.com"

# === Database location ===
# Default: ./data/dividend-dash.db
DD_DB_PATH=./data/dividend-dash.db

# === Logging ===
DD_LOG_LEVEL=info
